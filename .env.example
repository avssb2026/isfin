# Prisma Postgres (db.prisma.io) или любой управляемый PostgreSQL с SSL.
# В панели Prisma: скопируйте строку подключения в DATABASE_URL.
DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# Дубли для хостингов, где заданы отдельные имена переменных (опционально):
# PRISMA_POSTGRES_PRISMA_DATABASE_URL="..."
# PRISMA_POSTGRES_POSTGRES_URL="..."

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Публичный URL приложения (локально совпадает с AUTH_URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Калькулятор: запасное значение годового параметра, % (если БД недоступна)
NEXT_PUBLIC_DEFAULT_KEY_RATE_PERCENT="16"

# Seed: первый оператор (prisma/seed.ts)
SEED_OPERATOR_EMAIL="operator@example.com"
SEED_OPERATOR_PASSWORD="change-me-in-production"
