# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/isfin?schema=public"

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Public URL (same as AUTH_URL in dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Default key rate (annual, percent) used in calculator when env is set — e.g. 16.0
NEXT_PUBLIC_DEFAULT_KEY_RATE_PERCENT="16"

# Seed: initial operator (used by prisma/seed.ts)
SEED_OPERATOR_EMAIL="operator@example.com"
SEED_OPERATOR_PASSWORD="change-me-in-production"
