# Основная строка для Prisma (migrate / generate / приложение).
# На Vercel обязательно задать: при сборке выполняется prisma migrate deploy (миграции с каждым деплоем).
isfin_db_DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# Из Prisma Console (приложение может подставить в isfin_db_DATABASE_URL)
isfin_db_PRISMA_DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
isfin_db_POSTGRES_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# NextAuth — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Публичный URL приложения (на Vercel: https://<project>.vercel.app без слэша в конце)
AUTH_URL="http://localhost:3000"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_KEY_RATE_PERCENT="16"

SEED_OPERATOR_EMAIL="operator@example.com"
SEED_OPERATOR_PASSWORD="change-me-in-production"
